def runPipeline = {
    stage('Checkout') {
        checkout scm
    }

    properties([
        parameters([
            string(name: 'OPERATION', defaultValue: 'plan', description: 'plan or apply'),
            string(name: 'ENVIRONMENTS', defaultValue: '', description: 'comma-separated environments to target manually'),
            string(name: 'WORKDIR', defaultValue: '.', description: 'working directory for stacksmith commands'),
            booleanParam(name: 'FAIL_ON_CHANGES', defaultValue: false, description: 'fail if plan contains changes'),
            booleanParam(name: 'STRICT_VALIDATION_WARNINGS', defaultValue: false, description: 'treat validation warnings as failures'),
        ])
    ])

    stage('Validate Branch and Operation') {
        def operation = params.OPERATION.toLowerCase()

        if (env.CHANGE_ID && operation == 'apply') {
            error 'apply operation is not allowed on pull requests. Use plan instead.'
        }
        if (!env.CHANGE_ID && !env.BRANCH_IS_PRIMARY) {
            error "operations are only allowed on main branch or pull requests to main. Current branch: ${env.BRANCH_NAME}"
        }
    }

    stage('Select environments') {
        writeFile file: 'selection.json', text: '{}'
        withEnv([
            "INPUT_GITOPS_ROOT=${params.WORKDIR}",
            "INPUT_DISCOVERY_MODE=${env.STACKSMITH_DISCOVERY_MODE ?: 'folders'}",
            "INPUT_ENVIRONMENTS=${params.ENVIRONMENTS}",
        ]) {
            sh 'python3 scripts/select_gitops_environments.py >selection.json'
        }
        def selection = readJSON file: 'selection.json'
        env.SELECTED_ENVIRONMENTS = selection.selected_environments.join(',')
        env.COMMON_RUNFILE = selection.common_runfile
        env.SELECTION_MATRIX = writeJSON json: selection.matrix, returnText: true
    }

    stage('Summary') {
        if (!env.SELECTED_ENVIRONMENTS) {
            echo "No environments selected; skipping ${params.OPERATION}."
            currentBuild.result = 'SUCCESS'
            return
        }
        echo "Selected environments: ${env.SELECTED_ENVIRONMENTS}"
        echo "Common runfile: ${env.COMMON_RUNFILE}"
    }

    if (params.OPERATION.toLowerCase() == 'apply') {
        stage('Approval') {
            input "Proceed with apply for environments: ${env.SELECTED_ENVIRONMENTS}?"
        }
    }

    stage('Run Stacksmith') {
        def matrix = readJSON text: env.SELECTION_MATRIX
        def branches = [:]
        def results = [:]

        for (row in matrix) {
            def environment = row.environment
            def runfile = row.runfile
            branches[environment] = {
                try {
                    dir(params.WORKDIR) {
                        def command = "stacksmith ${params.OPERATION} --runfile ${runfile}"
                        if (params.FAIL_ON_CHANGES) {
                            command += " --fail-on-changes"
                        }
                        if (params.STRICT_VALIDATION_WARNINGS) {
                            command += " --strict-validation-warnings"
                        }
                        sh command
                    }
                    results[environment] = 'SUCCESS'
                } catch (e) {
                    echo "Error in environment ${environment}: ${e.message}"
                    results[environment] = 'FAILURE'
                }

                if (params.OPERATION.toLowerCase() == 'plan') {
                    dir(params.WORKDIR) {
                        archiveArtifacts artifacts: ".stacksmith/${environment}/**/*.json, .stacksmith/${environment}/**/*.csv", allowEmptyArchive: true
                    }
                }
            }
        }
        parallel branches

        def failedEnvs = results.findAll { it.value == 'FAILURE' }.collect { it.key }
        if (failedEnvs) {
            error "Stacksmith operation failed for environments: ${failedEnvs.join(', ')}"
        }
    }
}

if (env.STACKSMITH_NODE_LABEL) {
    node(env.STACKSMITH_NODE_LABEL) {
        runPipeline()
    }
} else {
    node {
        docker.image("cisourcerer/stacksmith:${env.STACKSMITH_IMAGE_VERSION ?: 'latest'}").inside {
            runPipeline()
        }
    }
}
