pipeline {
  agent {
    label "${env.STACKSMITH_AGENT_LABEL}"
  }

  options {
    ansiColor('xterm')
    timestamps()
  }

  environment {
    OPERATION = "${params.OPERATION ?: env.OPERATION ?: 'plan'}"
    GITOPS_ROOT = "${params.GITOPS_ROOT ?: env.STACKSMITH_GITOPS_ROOT ?: '.'}"
    DISCOVERY_MODE = "${params.DISCOVERY_MODE ?: env.STACKSMITH_DISCOVERY_MODE ?: 'folders'}"
    ENVIRONMENTS = "${params.ENVIRONMENTS ?: env.ENVIRONMENTS ?: ''}"
    ENV_FILE = "${env.STACKSMITH_ENV_FILE ?: '/dev/null'}"
    IMAGE_VERSION = "${env.STACKSMITH_IMAGE_VERSION ?: 'latest'}"
  }

  parameters {
    string(name: 'OPERATION', defaultValue: 'plan', description: 'plan or apply')
    string(name: 'GITOPS_ROOT', defaultValue: '.', description: 'Relative GitOps root folder')
    string(name: 'DISCOVERY_MODE', defaultValue: 'folders', description: 'folders, flat-files, or env-files')
    string(name: 'ENVIRONMENTS', defaultValue: '', description: 'Comma-separated environments to target manually')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Validate Branch and Operation') {
      steps {
        script {
          def operation = env.OPERATION?.toLowerCase()

          if (env.CHANGE_ID && operation == 'apply') {
            error "apply operation is not allowed on pull requests. Use plan instead."
          }
          if (!env.CHANGE_ID && !env.BRANCH_IS_PRIMARY) {
            error "operations are only allowed on main branch or pull requests to main. Current branch: ${env.BRANCH_NAME}"
          }
        }
      }
    }

    stage('Select Environments') {
      steps {
        script {
          writeFile file: 'selection.json', text: '{}'
          withEnv([
            "INPUT_GITOPS_ROOT=${env.GITOPS_ROOT}",
            "INPUT_DISCOVERY_MODE=${env.DISCOVERY_MODE}",
            "INPUT_ENVIRONMENTS=${env.ENVIRONMENTS}",
          ]) {
            sh 'python3 scripts/select_gitops_environments.py >selection.json'
          }
          def selection = readJSON file: 'selection.json'
          env.SELECTED_ENVIRONMENTS = selection.selected_environments.join(',')
          env.COMMON_RUNFILE = selection.common_runfile
          env.SELECTION_MATRIX = writeJSON json: selection.matrix, returnText: true
        }
      }
    }

    stage('Summary') {
      steps {
        script {
          if (!env.SELECTED_ENVIRONMENTS) {
            echo "No environments selected; skipping ${env.OPERATION}."
            currentBuild.result = 'SUCCESS'
            return
          }
          echo "Selected environments: ${env.SELECTED_ENVIRONMENTS}"
          echo "Common runfile: ${env.COMMON_RUNFILE}"
        }
      }
    }

    stage('Run Stacksmith') {
      when {
        expression { env.SELECTED_ENVIRONMENTS }
      }
      steps {
        script {
          def helper = load 'jenkins/stacksmith-helpers.groovy'
          def matrix = readJSON text: env.SELECTION_MATRIX
          def branches = [:]
          for (row in matrix) {
            branches[row.environment] = {
              node(env.STACKSMITH_AGENT_LABEL) {
                withEnv([
                  "STACKSMITH_ENV_FILE=${env.ENV_FILE}",
                  "STACKSMITH_IMAGE_VERSION=${env.IMAGE_VERSION}",
                  "ENVIRONMENT=${row.environment}",
                  "RUNFILE=${row.runfile}",
                ]) {
                  helper.runStacksmith(env.OPERATION, row.runfile, row.environment, env.ENV_FILE)
                }
              }
            }
          }
          parallel branches
        }
      }
    }
  }
}
